# Teller API Configuration
# Get these from https://teller.io/dashboard
TELLER_ENVIRONMENT=development
TELLER_API_KEY=your_teller_api_key_here
TELLER_APP_ID=your_app_id_here
TELLER_CERT_PATH=path/to/certificate.pem
TELLER_KEY_PATH=path/to/private_key.pem

# Google Sheets Configuration
# Get Sheet ID from your Google Sheet URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
SPREADSHEET_ID=your_google_sheet_id_here
SHEET_NAME=Sheet1

# Person Names - CUSTOMIZE THESE!
# These names will appear in your Google Sheet headers
# Example: "Alice Owes" and "Bob Owes"
PERSON_1_NAME=Person 1
PERSON_2_NAME=Person 2

# CSV Watch Folder
CSV_WATCH_FOLDER=./csv_imports

# Backend API URL (for CSV watcher)
BACKEND_URL=http://localhost:8000